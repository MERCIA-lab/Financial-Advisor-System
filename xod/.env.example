# XOD Production Environment Variables
# Copy this file to .env and update with your production values

# Database Configuration
DB_USER=xod_prod
DB_PASSWORD=your_secure_db_password_here

# JWT Configuration
JWT_SECRET=your_32_character_jwt_secret_here_minimum_256_bits

# CORS Configuration (comma-separated URLs)
CORS_ORIGINS=https://your-frontend-domain.vercel.app,https://your-frontend-domain.onrender.com

# API Configuration
API_BASE_URL=https://your-backend-domain.onrender.com

# Grafana Configuration
GRAFANA_PASSWORD=your_secure_grafana_password

# SSL Configuration (if using HTTPS)
SSL_CERT_PATH=/etc/nginx/ssl/cert.pem
SSL_KEY_PATH=/etc/nginx/ssl/key.pem

# Monitoring
PROMETHEUS_RETENTION=200h
GRAFANA_ADMIN_USER=admin

# Redis Configuration (Optional)
REDIS_PASSWORD=your_redis_password
REDIS_MAX_MEMORY=256mb

# Logging
LOG_LEVEL=INFO
LOG_MAX_SIZE=100m
LOG_MAX_FILES=5

# Performance
JVM_XMX=1g
JVM_XMS=512m

# Security
SECURITY_HEADERS=true
RATE_LIMIT_REQUESTS_PER_MINUTE=100
SESSION_TIMEOUT_MINUTES=30